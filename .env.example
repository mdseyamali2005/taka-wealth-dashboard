# Environment variables for TakaTrack

# ─── Database Connection (Microsoft SQL Server) ─────────────────
# Format: sqlserver://HOST:PORT;database=DATABASE_NAME;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true;
DATABASE_URL="sqlserver://localhost:1433;database=TakaWealth;user=sa;password=your_password;encrypt=true;trustServerCertificate=true;"

# ─── Express Server Port ─────────────────────────────────────────
PORT=3000

# ─── Authentication ──────────────────────────────────────────────
# JWT secret for signing tokens (generate a random 64-char string)
JWT_SECRET="your-random-64-character-secret-key-here-change-this-in-production"

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI Chat ─────────────────────────────────────────────────────
# Anthropic Claude API key (from console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# OpenAI API key for Whisper STT (from platform.openai.com)
OPENAI_API_KEY="sk-your-openai-key-here"

# ─── Stripe Subscription ────────────────────────────────────────
# Stripe secret key (from Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"

# Stripe webhook signing secret (from Stripe CLI or Dashboard)
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price ID for monthly plan (from Stripe Dashboard → Products)
STRIPE_PRICE_ID="price_your-monthly-plan-price-id"

# ─── Frontend Environment Variables (Vite) ──────────────────────
# These are exposed to the browser (prefixed with VITE_)
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
