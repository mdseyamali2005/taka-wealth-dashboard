// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id                 Int           @id @default(autoincrement())
  email              String        @unique
  name               String?
  password           String        // bcrypt hash (nullable for Google-only users)
  googleId           String?
  avatarUrl          String?
  subscriptionStatus String        @default("free") // "free" | "active" | "canceled" | "past_due"
  paymentCustomerId  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  transactions       Transaction[]
  sessions           Session[]
  chatMessages       ChatMessage[]
  loginLogs          LoginLog[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String
  type        String   // "income" or "expense"
  date        DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  ip        String?
  location  String?
  device    String?
  browser   String?
  os        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  role      String   // "user" | "assistant"
  content   String   @db.NVarChar(Max)
  createdAt DateTime @default(now())
}

model LoginLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  email       String
  ip          String
  location    String?  // "Dhaka, Bangladesh" from IP geolocation
  device      String?  // "Desktop", "Mobile", "Tablet"
  browser     String?  // "Chrome 125", "Firefox 130"
  os          String?  // "Windows 11", "Android 14", "macOS 15"
  userAgent   String?  @db.NVarChar(Max)
  loginMethod String   // "email" | "google" | "register"
  createdAt   DateTime @default(now())
}
